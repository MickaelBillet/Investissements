@page "/"
@inject DashboardViewModel ViewModel
@inject ILocalizationService L

<PageTitle>Portefeuille — Suivi des Investissements</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="loading-screen">
        <span class="loading-text">@L.Translate("Loading")</span>
    </div>
}
else if (ViewModel.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@ViewModel.ErrorMessage</MudAlert>
}
else
{
    <MudStack Spacing="6">

        <KpiHeader Snapshot="@ViewModel.LastSnapshot"
                   AssetCount="@ViewModel.AssetCount"
                   RoiOnCapitalEngaged="@ViewModel.PortfolioRoiOnCapitalEngaged"
                   RoiOnTotalPurchases="@ViewModel.PortfolioRoiOnTotalPurchases"
                   AverageRisk="@ViewModel.AverageRisk"
                   DailyVariationPercent="@ViewModel.DailyVariationPercent"
                   WeeklyVariationPercent="@ViewModel.WeeklyVariationPercent"
                   MonthlyVariationPercent="@ViewModel.MonthlyVariationPercent"
                   YtdVariationPercent="@ViewModel.YtdVariationPercent"
                   YearlyVariationPercent="@ViewModel.YearlyVariationPercent"
                   DailyROICapitalEngagedVariation="@ViewModel.DailyROICapitalEngagedVariation"
                   WeeklyROICapitalEngagedVariation="@ViewModel.WeeklyROICapitalEngagedVariation"
                   MonthlyROICapitalEngagedVariation="@ViewModel.MonthlyROICapitalEngagedVariation"
                   YtdROICapitalEngagedVariation="@ViewModel.YtdROICapitalEngagedVariation"
                   YearlyROICapitalEngagedVariation="@ViewModel.YearlyROICapitalEngagedVariation"
                   DailyROITotalPurchasesVariation="@ViewModel.DailyROITotalPurchasesVariation"
                   WeeklyROITotalPurchasesVariation="@ViewModel.WeeklyROITotalPurchasesVariation"
                   MonthlyROITotalPurchasesVariation="@ViewModel.MonthlyROITotalPurchasesVariation"
                   YtdROITotalPurchasesVariation="@ViewModel.YtdROITotalPurchasesVariation"
                   YearlyROITotalPurchasesVariation="@ViewModel.YearlyROITotalPurchasesVariation" />

        @if (_activeHierarchy == ActiveHierarchy.None)
        {
            <MudGrid Spacing="4">
                <MudItem xs="12" md="4">
                    <DrillDownDonut Title="@ViewModel.GetPanelTitle(ViewModel.AssetClassPanel)"
                                    Items="@ViewModel.GetDistribution(ViewModel.AssetClassPanel)"
                                    Colors="@_assetClassColors"
                                    OnSliceClicked="@(name => DrillDown(ActiveHierarchy.AssetClass, ViewModel.AssetClassPanel, name))" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <DrillDownDonut Title="@ViewModel.GetPanelTitle(ViewModel.SupportTypePanel)"
                                    Items="@ViewModel.GetDistribution(ViewModel.SupportTypePanel)"
                                    Colors="@_supportTypeColors"
                                    OnSliceClicked="@(name => DrillDown(ActiveHierarchy.SupportType, ViewModel.SupportTypePanel, name))" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <DrillDownDonut Title="@ViewModel.GetPanelTitle(ViewModel.RiskPanel)"
                                    Items="@ViewModel.GetDistribution(ViewModel.RiskPanel)"
                                    Colors="@_riskColors"
                                    OnSliceClicked="@(name => DrillDown(ActiveHierarchy.Risk, ViewModel.RiskPanel, name))" />
                </MudItem>
            </MudGrid>
        }
        else
        {
            var panel  = ActivePanel;
            var colors = ActiveColors;
            <MudGrid Spacing="4">
                <MudItem xs="12" md="5">
                    <DrillDownDonut @key="@($"{_activeHierarchy}:{panel.Level}:{ViewModel.EtfStocksGroupByInformation}")"
                                    Title="@ViewModel.GetPanelTitle(panel)"
                                    Items="@ViewModel.GetDistribution(panel)"
                                    CanGoBack="true"
                                    Height="500"
                                    Colors="@colors"
                                    OnSliceClicked="@(name => DrillDown(_activeHierarchy, panel, name))"
                                    OnBackClicked="@(() => GoBack(panel))">
                        <TopRightContent>
                            @if (_activeHierarchy == ActiveHierarchy.AssetClass && panel.Selected(1) == "ETF_Stocks")
                            {
                                <MudSwitch T="bool"
                                           @bind-Value="@ViewModel.EtfStocksGroupByInformation"
                                           Label="@L.Translate("GroupByTheme")"
                                           Color="MudBlazor.Color.Primary" />
                            }
                        </TopRightContent>
                    </DrillDownDonut>
                </MudItem>
                <MudItem xs="12" md="7">
                    @{
                        var geoClass = _activeHierarchy == ActiveHierarchy.AssetClass && panel.Level == 1
                            && (panel.Selected(0) == "Stocks" || panel.Selected(0) == "Bonds")
                            ? panel.Selected(0)
                            : null;
                    }
                    @if (geoClass is not null && _selectedZone is null && _selectedSector is null)
                    {
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <DrillDownDonut @key="@($"geo:{geoClass}")"
                                                Title="@($"Zones géographiques — {ViewModel.GetPanelTitle(panel)}")"
                                                Items="@ViewModel.GetGeographyForClass(geoClass)"
                                                Colors="@_geographyColors"
                                                OnSliceClicked="@(zone => { _selectedZone = zone; _selectedSector = null; })" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <DrillDownDonut @key="@($"sector:{geoClass}")"
                                                Title="@($"Secteurs — {ViewModel.GetPanelTitle(panel)}")"
                                                Items="@ViewModel.GetSectorForClass(geoClass)"
                                                Colors="@_sectorColors"
                                                OnSliceClicked="@(sector => { _selectedSector = sector; _selectedZone = null; })" />
                            </MudItem>
                        </MudGrid>
                    }
                    else if (geoClass is not null && _selectedZone is not null)
                    {
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                                       Style="align-self: flex-start;"
                                       OnClick="@(() => _selectedZone = null)">
                                @L.Translate("Back")
                            </MudButton>
                            <AssetTable Title="@($"{ViewModel.GetPanelTitle(panel)} — {_selectedZone}")"
                                    Assets="@ViewModel.GetAssetsForZone(geoClass, _selectedZone)" />
                        </MudStack>
                    }
                    else if (geoClass is not null && _selectedSector is not null)
                    {
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                                       Style="align-self: flex-start;"
                                       OnClick="@(() => _selectedSector = null)">
                                @L.Translate("Back")
                            </MudButton>
                            <AssetTable Title="@($"{ViewModel.GetPanelTitle(panel)} — {_selectedSector}")"
                                        Assets="@ViewModel.GetAssetsForSector(geoClass, _selectedSector)" />
                        </MudStack>
                    }
                    else if (ViewModel.IsLeafLevel(panel))
                    {
                        <AssetTable Title="@ViewModel.GetPanelTitle(panel)"
                                    Assets="@ViewModel.GetAssetsForPanel(panel)" />
                    }
                    else
                    {
                        <DistributionTable Items="@ViewModel.GetDistribution(panel)" />
                    }
                </MudItem>
            </MudGrid>
        }

    </MudStack>
}

@code {
    private enum ActiveHierarchy { None, AssetClass, SupportType, Risk }

    private ActiveHierarchy _activeHierarchy = ActiveHierarchy.None;
    private string?         _selectedZone;
    private string?         _selectedSector;

    private static readonly string[] _assetClassColors =
        ["#CE8BA0", "#E06D6D", "#4DAB9A", "#9B8DD6", "#D4A844", "#A0A0A0", "#787774", "#2383E2"];

    private static readonly string[] _supportTypeColors =
        ["#A0A0A0", "#4DAB9A", "#9B8DD6", "#2383E2", "#CE8BA0", "#D4A844"];

    private static readonly string[] _riskColors =
        ["#4DAB9A", "#A0A0A0", "#D4A844", "#CE8BA0", "#E06D6D"];

    private static readonly string[] _geographyColors =
        ["#2383E2", "#4DAB9A", "#D4A844", "#CE8BA0", "#E06D6D", "#9B8DD6", "#A0A0A0", "#787774"];

    private static readonly string[] _sectorColors =
        ["#D4A844", "#CE8BA0", "#9B8DD6", "#4DAB9A", "#E06D6D", "#2383E2", "#787774", "#A0A0A0"];

    private PanelState ActivePanel => _activeHierarchy switch
    {
        ActiveHierarchy.AssetClass  => ViewModel.AssetClassPanel,
        ActiveHierarchy.SupportType => ViewModel.SupportTypePanel,
        _                           => ViewModel.RiskPanel
    };

    private string[] ActiveColors => _activeHierarchy switch
    {
        ActiveHierarchy.AssetClass  => _assetClassColors,
        ActiveHierarchy.SupportType => _supportTypeColors,
        _                           => _riskColors
    };

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }

    private void DrillDown(ActiveHierarchy hierarchy, PanelState panel, string name)
    {
        if (ViewModel.IsLeafLevel(panel)) return;
        _activeHierarchy = hierarchy;
        _selectedZone    = null;
        _selectedSector  = null;
        panel.DrillDown(name);
    }

    private void GoBack(PanelState panel)
    {
        _selectedZone   = null;
        _selectedSector = null;
        panel.GoBack();
        if (!panel.CanGoBack)
            _activeHierarchy = ActiveHierarchy.None;
    }
}
