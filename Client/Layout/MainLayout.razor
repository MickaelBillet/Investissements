@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudSnackbarProvider />
<MudDialogProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Color="MudBlazor.Color.Surface"
               Style="border-bottom:1px solid #E9E9E7;">
        <MudText Style="font-size:18px;font-weight:700;color:#37352F;">
            Suivi des Investissements
        </MudText>
        <MudSpacer />
        <MudButton Href="/" Color="MudBlazor.Color.Default" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Outlined.PieChart">
            Portefeuille
        </MudButton>
        <MudButton Href="/historique" Color="MudBlazor.Color.Default" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Outlined.Timeline">
            Historique
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge"
                      Style="padding-top:32px;padding-bottom:48px;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Background       = "#FFFFFF",
            Surface          = "#FAFAFA",
            TextPrimary      = "#37352F",
            TextSecondary    = "#787774",
            Primary          = "#2383E2",
            PrimaryContrastText = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText       = "#37352F",
            TableLines       = "#E9E9E7",
            TableStriped     = "#FAFAFA",
            TableHover       = "#FAFAFA",
            Divider          = "#E9E9E7",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Helvetica", "Arial", "sans-serif"],
                FontSize   = "14px",
                FontWeight = "400"
            },
            H1 = new H1Typography { FontSize = "40px", FontWeight = "700" },
            H2 = new H2Typography { FontSize = "24px", FontWeight = "600" },
            H3 = new H3Typography { FontSize = "18px", FontWeight = "600" },
        },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "6px" }
    };
}
