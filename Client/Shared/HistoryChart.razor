@inject ILocalizationService L

<MudPaper Elevation="0" Style="border:1px solid #E9E9E7;border-radius:6px;padding:16px 20px;height:100%;display:flex;flex-direction:column;">
    <MudText Style="font-size:18px;font-weight:600;color:#37352F;margin-bottom:16px;">
        @L.Translate("Chart_RelativePerf")
    </MudText>

    @if (ROIC_Series.Count == 0)
    {
        <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="min-height:300px;">
            <MudText Typo="Typo.body2" Style="color:#787774;">@L.Translate("Empty_NoHistoricalData")</MudText>
        </MudStack>
    }
    else
    {
        <div style="flex:1;min-height:0;">
        <ApexChart TItem="IndexedPoint" Options="_options">
            <ApexPointSeries TItem="IndexedPoint"
                             Items="@ROIC_Series"
                             Name="@L.Translate("Chart_Series_ROIC")"
                             SeriesType="SeriesType.Line"
                             XValue="@(e => e.Date.ToString("dd/MM/yy"))"
                             YValue="@(e => (decimal)e.Value)" />
            <ApexPointSeries TItem="IndexedPoint"
                             Items="@LifeStrategySeries"
                             Name="@L.Translate("Chart_Series_LifeStrategy")"
                             SeriesType="SeriesType.Line"
                             XValue="@(e => e.Date.ToString("dd/MM/yy"))"
                             YValue="@(e => (decimal)e.Value)" />
            <ApexPointSeries TItem="IndexedPoint"
                             Items="@MsciWorldSeries"
                             Name="@L.Translate("Chart_Series_MsciWorld")"
                             SeriesType="SeriesType.Line"
                             XValue="@(e => e.Date.ToString("dd/MM/yy"))"
                             YValue="@(e => (decimal)e.Value)" />
        </ApexChart>
        </div>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<IndexedPoint> ROIC_Series { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<IndexedPoint> LifeStrategySeries { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<IndexedPoint> MsciWorldSeries    { get; set; } = [];

    protected override void OnParametersSet()
    {
        var allValues = ROIC_Series
            .Concat(LifeStrategySeries)
            .Concat(MsciWorldSeries)
            .Select(p => p.Value)
            .ToList();

        if (allValues.Count == 0) return;

        _options.Yaxis[0].Min = allValues.Min() - 30;
        _options.Yaxis[0].Max = allValues.Max() + 30;
    }

    private readonly ApexChartOptions<IndexedPoint> _options = new()
    {
        Chart = new Chart
        {
            Background = "transparent",
            Toolbar    = new Toolbar { Show = false },
            Type       = ApexCharts.ChartType.Line,
            Height     = "100%"
        },
        Colors  = ["#FF6B6B", "#2383E2", "#4DAB9A", "#787774"],
        Stroke  = new Stroke { Curve = Curve.Smooth, Width = [2, 2, 2] },
        Xaxis   = new XAxis
        {
            Type   = XAxisType.Category,
            Labels = new XAxisLabels
            {
                Style = new AxisLabelStyle { Colors = "#787774", FontSize = "12px" }
            }
        },
        Yaxis = [new YAxis
        {
            Labels = new YAxisLabels
            {
                Formatter = "function(val) { return val.toFixed(1); }"
            }
        }],
        Legend     = new Legend { Position = LegendPosition.Bottom },
        Grid       = new Grid { BorderColor = "#E9E9E7" },
        DataLabels = new DataLabels { Enabled = false }
    };
}
