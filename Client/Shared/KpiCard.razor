<MudItem xs="12" sm="4">
    <MudCard Elevation="0">
        <MudCardContent Style="padding:8px 12px;">
            <MudText Typo="Typo.caption" Style="color:#787774;">@Label</MudText>
            <MudText Style="font-size:20px;font-weight:700;color:#37352F;line-height:1.2;margin-top:2px;"
                     Class="@ValueClass">
                @Value
            </MudText>
        </MudCardContent>
    </MudCard>
</MudItem>

@code {
    [Parameter, EditorRequired] public string Label      { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value      { get; set; } = string.Empty;
    [Parameter]                 public string ValueClass { get; set; } = string.Empty;
}
