<MudItem xs="12" sm="4">
    <MudCard Elevation="0">
        <MudCardContent>
            <MudText Typo="Typo.body2" Style="color:#787774;">@Label</MudText>
            <MudText Style="font-size:36px;font-weight:700;color:#37352F;line-height:1.2;margin-top:4px;">
                @Value
            </MudText>
        </MudCardContent>
    </MudCard>
</MudItem>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
}
