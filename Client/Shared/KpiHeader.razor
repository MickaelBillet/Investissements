@using InvestissementsDashboard.Client.Extensions
@inject ILocalizationService L

<MudGrid Spacing="4">
    <KpiCard Label="@L.Translate("Kpi_TotalValue")" Value="@(Snapshot?.PortfolioTotal.ToEurAmount() ?? "—")">
        <SubContent>
            @VariationChips(
                ("Kpi_DailyPrefix",   DailyVariationPercent),
                ("Kpi_WeeklyPrefix",  WeeklyVariationPercent),
                ("Kpi_MonthlyPrefix", MonthlyVariationPercent),
                ("Kpi_YtdPrefix",     YtdVariationPercent),
                ("Kpi_YearlyPrefix",  YearlyVariationPercent))
        </SubContent>
    </KpiCard>
    <KpiCard Label="@L.Translate("Kpi_LastUpdate")"   Value="@(Snapshot?.Date.ToString("dd/MM/yyyy") ?? "—")" />
    <KpiCard Label="@L.Translate("Kpi_AssetCount")" Value="@AssetCount.ToString()" />
    <KpiCard Label="@L.Translate("Kpi_RoiCapital")" Value="@(RoiOnCapitalEngaged?.ToPercentage() ?? L.Translate("Kpi_NotAvailable"))"
             ValueClass="@RoiOnCapitalEngaged.CssRoiClass()">
        <SubContent>
            @VariationChips(
                ("Kpi_DailyPrefix",   DailyROICapitalEngagedVariation),
                ("Kpi_WeeklyPrefix",  WeeklyROICapitalEngagedVariation),
                ("Kpi_MonthlyPrefix", MonthlyROICapitalEngagedVariation),
                ("Kpi_YtdPrefix",     YtdROICapitalEngagedVariation),
                ("Kpi_YearlyPrefix",  YearlyROICapitalEngagedVariation))
        </SubContent>
    </KpiCard>
    <KpiCard Label="@L.Translate("Kpi_AverageRisk")"   Value="@(AverageRisk?.ToString("F2") ?? "—")" />
</MudGrid>

@code {
    [Parameter, EditorRequired] public SnapshotDto? Snapshot                { get; set; }
    [Parameter, EditorRequired] public int          AssetCount              { get; set; }
    [Parameter]                 public decimal?     RoiOnCapitalEngaged     { get; set; }
    [Parameter]                 public decimal?     AverageRisk             { get; set; }
    [Parameter]                 public decimal?     DailyVariationPercent              { get; set; }
    [Parameter]                 public decimal?     WeeklyVariationPercent             { get; set; }
    [Parameter]                 public decimal?     MonthlyVariationPercent            { get; set; }
    [Parameter]                 public decimal?     YtdVariationPercent                { get; set; }
    [Parameter]                 public decimal?     YearlyVariationPercent             { get; set; }
    [Parameter]                 public decimal?     DailyROICapitalEngagedVariation    { get; set; }
    [Parameter]                 public decimal?     WeeklyROICapitalEngagedVariation   { get; set; }
    [Parameter]                 public decimal?     MonthlyROICapitalEngagedVariation  { get; set; }
    [Parameter]                 public decimal?     YtdROICapitalEngagedVariation      { get; set; }
    [Parameter]                 public decimal?     YearlyROICapitalEngagedVariation   { get; set; }

    // Renders one small signed-percentage chip per period that has a value.
    private RenderFragment VariationChips(params (string Prefix, decimal? Value)[] variations) => @<text>
        @if (variations.Any(v => v.Value.HasValue))
        {
            <MudStack Row="true" Spacing="1" Style="margin-top:4px;flex-wrap:wrap;">
                @foreach (var variation in variations.Where(v => v.Value.HasValue))
                {
                    <MudChip T="string" Size="MudBlazor.Size.Small"
                             Class="@variation.Value.CssRoiClass()"
                             Style="height:22px;font-size:12px;padding:0 7px;">
                        @L.Translate(variation.Prefix) @variation.Value!.Value.ToSignedPercentage()
                    </MudChip>
                }
            </MudStack>
        }
    </text>;
}
