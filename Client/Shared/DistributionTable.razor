@using InvestissementsDashboard.Client.Extensions

<MudTable Items="@Items" Dense="true" Hover="true" Elevation="0"
          Style="border:1px solid #E9E9E7;border-radius:6px;margin-top:16px;">
    <HeaderContent>
        <MudTh Style="color:#787774;font-size:12px;">Nom</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">Valeur actuelle</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">Poids</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom" Style="font-weight:500;">@context.Label</MudTd>
        <MudTd DataLabel="Valeur actuelle" Style="text-align:right;">
            @context.CurrentTotal.ToEurAmount()
        </MudTd>
        <MudTd DataLabel="Poids" Style="text-align:right;">
            @context.Weight.ToPercentage(1)
        </MudTd>
    </RowTemplate>
    <FooterContent>
        <MudTd Style="font-weight:600;">Total</MudTd>
        <MudTd Style="text-align:right;font-weight:600;">
            @Items.Sum(i => i.CurrentTotal).ToEurAmount()
        </MudTd>
        <MudTd />
    </FooterContent>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="color:#787774;padding:16px;">Aucune donnée</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DistributionItem> Items { get; set; } = [];
}
