@inject ILocalizationService L

<MudTable Items="@Assets" Dense="true" Hover="true" Elevation="0"
          Style="border:1px solid #E9E9E7;border-radius:6px;margin-top:16px;">
    <HeaderContent>
        <MudTh Style="color:#787774;font-size:12px;">@L.Translate("Col_Name")</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">@L.Translate("Col_CurrentValue")</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">@L.Translate("Col_UnrealizedGain")</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">@L.Translate("Col_ROI")</MudTh>
        <MudTh Style="color:#787774;font-size:12px;text-align:right;">@L.Translate("Col_Yield")</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L.Translate("Col_Name")" Style="font-weight:500;">@context.Name</MudTd>
        <MudTd DataLabel="@L.Translate("Col_CurrentValue")" Style="text-align:right;">
            @context.CurrentTotal.ToEurAmount()
        </MudTd>
        <MudTd DataLabel="@L.Translate("Col_UnrealizedGain")" Style="text-align:right;"
               Class="@context.UnrealizedGain.CssRoiClass()">
            @context.UnrealizedGain.ToEurAmount()
        </MudTd>
        <MudTd DataLabel="@L.Translate("Col_ROI")" Style="text-align:right;"
               Class="@context.Roi.CssRoiClass()">
            @context.Roi.ToPercentage()
        </MudTd>
        <MudTd DataLabel="@L.Translate("Col_Yield")" Style="text-align:right;">
            @context.Yield.ToPercentage()
        </MudTd>
    </RowTemplate>
    <FooterContent>
        <MudTd Style="font-weight:600;">@L.Translate("Table_Total")</MudTd>
        <MudTd Style="text-align:right;font-weight:600;">
            @Assets.Sum(a => a.CurrentTotal ?? 0m).ToEurAmount()
        </MudTd>
        <MudTd /><MudTd /><MudTd />
    </FooterContent>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="color:#787774;padding:16px;">@L.Translate("Empty_NoAsset")</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<AssetDto> Assets { get; set; } = [];
}
